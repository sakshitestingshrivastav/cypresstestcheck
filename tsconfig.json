{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "types": ["cypress", "node"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "strict": false,
    "ignoreDeprecations": "6.0",
    "baseUrl": "https://opensource-demo.orangehrmlive.com",
    "paths": {
      "@pages/*": ["cypress/pages/*"],
      "@fixtures/*": ["cypress/fixtures/*"]
    }
  },

  "include": [
    "**/*.ts"
  ]
}